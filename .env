# ===========================================
# 数据库配置
# ===========================================

# 数据库文件路径。如果未设置，将根据仓库路径自动生成哈希作为文件名，
# 保存在 ~/.context/{repo_hash}.db 目录下
# 默认值: ~/.context/{repo_hash}.db
CE_DB_PATH=/home/fx2h/Projects/Python/context-engine/index_db/context_engine.db

# ===========================================
# 仓库配置
# ===========================================

# 索引的仓库根目录路径
# 默认值: 当前工作目录
CE_REPO_ROOT=/path/to/your/repo

# 排除的目录和文件模式，逗号分隔
# 默认值: node_modules,__pycache__,.git,dist,build
CE_EXCLUDE_PATTERNS=node_modules,__pycache__,.git,dist,build,venv,.venv,tests

# ===========================================
# 索引配置
# ===========================================

# 最大文件大小（字节），超过此大小的文件将被跳过
# 默认值: 500000 (约 500KB)
CE_MAX_FILE_SIZE=500000

# 并行解析的线程数，提高索引速度
# 默认值: 4
CE_PARALLEL_WORKERS=4

# ===========================================
# 文件监听配置
# ===========================================

# 文件变更防抖时间（秒），避免文件频繁变更导致的重复索引
# 默认值: 0.5
CE_WATCHER_DEBOUNCE=0.5

# ===========================================
# 查询缓存配置
# ===========================================

# 是否启用查询缓存，提高重复查询的性能
# 默认值: true
CE_ENABLE_CACHE=true

# 缓存最大条目数，超过后将自动淘汰最久未使用的条目
# 默认值: 1000
CE_CACHE_SIZE=1000

# ===========================================
# 日志配置
# ===========================================

# 日志级别：DEBUG, INFO, WARNING, ERROR
# 默认值: INFO
CE_LOG_LEVEL=INFO

# 是否使用 JSON 格式输出日志，便于日志聚合和分析
# 默认值: false
CE_JSON_LOGS=false

# 日志文件路径（可选），如果设置日志将写入文件而非控制台
# 默认值: None
CE_LOG_FILE=/tmp/context-engine.log
